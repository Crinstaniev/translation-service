FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    TRANSLATION_SERVICE_HOST=0.0.0.0 \
    TRANSLATION_SERVICE_PORT=8010

WORKDIR /service

COPY pyproject.toml ./
COPY app ./app

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir .

EXPOSE 8010

CMD ["python", "-m", "app.main"]

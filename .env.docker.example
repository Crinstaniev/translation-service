# Copy this file to .env before running Docker Compose if you need overrides.

VLLM_MODEL_PATH=/home/crinstaniev/models/HY-MT1.5-7B-GPTQ-Int4
VLLM_IMAGE=vllm/vllm-openai:latest
API_IMAGE=translation-service-api:local
WEB_IMAGE=translation-service-web:local
VLLM_MODEL_NAME=hy-mt15-7b
VLLM_PORT=8000
VLLM_GPU_MEMORY_UTILIZATION=0.82
VLLM_MAX_MODEL_LEN=2048
VLLM_MAX_NUM_SEQS=4

TRANSLATION_SERVICE_PORT=8010
VLLM_REQUEST_TIMEOUT_SECONDS=60
TRANSLATION_TEMPERATURE=0.3
TRANSLATION_TOP_P=0.6
TRANSLATION_TOP_K=20
TRANSLATION_REPETITION_PENALTY=1.05
TRANSLATION_HISTORY_LIMIT=500
STRICT_HEALTHCHECK=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

WEB_PORT=5173
VITE_API_BASE_URL=/api
